# ─────────────────────────────────────────────────────────────────────────────
# Maison Aurore Roster — environment variables
#
# Copy this file to .env and fill in your Supabase project credentials:
#   Supabase Dashboard → Project Settings → API
#
# Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# Your Supabase project URL (e.g. https://xxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=

# Your Supabase anon/public key (safe to expose in the browser)
VITE_SUPABASE_ANON_KEY=
